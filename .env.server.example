BOT_TOKEN=your_telegram_bot_token
DATABASE_URL=postgresql://taskbot:taskbot_secret@db:5432/taskbot

# Gemini planner
GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
PRIMARY_CHAT_MODEL=gemini-2.5-flash
FALLBACK_CHAT_MODEL=gemini-2.5-pro
AI_AGENT_MODE=true

# Voice/STT stays on the current provider in v1
STT_API_KEY=your_stt_api_key
STT_BASE_URL=https://api.onlysq.ru/ai/openai/
PRIMARY_STT_MODEL=whisper-large-v3-turbo
FALLBACK_STT_MODEL=

# Selective proxy routing for Gemini only.
# Telegram API, Postgres and STT provider should stay in NO_PROXY.
NODE_OPTIONS=--use-env-proxy
HTTPS_PROXY=http://gluetun:8888
HTTP_PROXY=http://gluetun:8888
NO_PROXY=db,localhost,127.0.0.1,api.telegram.org,api.onlysq.ru

# Gluetun VPN sidecar
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
WIREGUARD_PUBLIC_KEY=
WIREGUARD_ENDPOINT_IP=
WIREGUARD_ENDPOINT_PORT=
VPN_SERVER_COUNTRIES=
VPN_SERVER_CITIES=

# If your VPN provider uses OpenVPN instead of WireGuard:
OPENVPN_USER=
OPENVPN_PASSWORD=
